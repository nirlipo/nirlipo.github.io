@Thesis{lingfei-thesis,
 abstract = {High Performance Computing (HPC) systems are designed to execute large-scale computational workloads by leveraging parallel processing across multiple compute nodes. Efficient job scheduling in HPC environments is essential to ensure timely job completion and effective resource utilization. This thesis develops a Deep Reinforcement Learning (DRL)-based approach to HPC job scheduling that addresses key challenges including handling unbounded job queues, jointly managing job selection and resource allocation, dynamically adjusting scheduling objectives based on system conditions, and enabling transfer learning for adaptation to evolving HPC architectures. The research makes contributions including a DRL-based job selector for efficient backfilling, a hierarchical DRL scheduler for joint job selection and resource allocation, a dynamic controller for real-time objective adjustment, and a transfer learning framework for scheduler adaptation.},
 address = {Melbourne, Australia},
 author = {Lingfei Wang},
 month = {December},
 school = {The University of Melbourne},
 title = {Job Scheduling in High Performance Computing Clusters with Deep Reinforcement Learning},
 type = {PhD thesis},
 url = {https://minerva-access.unimelb.edu.au/items/0a6b0384-e919-4942-b75d-8a6cd2c64ba4},
 year = {2025}
}
