 address = {Melbourne, Australia},
 author = {Zihang Su},
 month = {December},
 school = {The University of Melbourne},
 title = {Bridging the Gap between Process Mining and Goal-Plan-Intention Recognition},
 type = {PhD thesis},
 url = {https://minerva-access.unimelb.edu.au/items/40607420-9945-4f42-9881-a099e216a537},
 year = {2024}
}
