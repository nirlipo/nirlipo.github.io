@Thesis{sukai-thesis,
 abstract = {Natural language (NL) offers an intuitive interface for humans to specify tasks for AI systems, enabling lay users to program agents without formal coding. However, NL's lack of precision introduces critical challenges for sequential decision-making (SDM) systems: noise can steer agents toward undesired behaviors, while ambiguity leads to inconsistent interpretations and invalid decisions. As AI systems increasingly adopt NL as their primary input modality, addressing these challenges become essential. This thesis investigates how NL can reliably be integrated into SDM systems across two dominant paradigms: model-free reinforcement learning (RL), where agents learn policies through trial-and-error, and model-based automated planning, where agents reason over explicit representations of the problems to generate solutions. We expose critical limitations in existing approaches, propose novel solutions, and re-evaluate assumptions about large language model (LLM)-based SDM systems to clarify their capabilities and constraints.},
 address = {Melbourne, Australia},
 author = {Sukai Huang},
 school = {The University of Melbourne},
 title = {Integrating Natural Language in Sequential Decision Problems},
 type = {PhD thesis},
 url = {https://minerva-access.unimelb.edu.au/items/329ad365-c4f5-4141-8a58-8da84b127753},
 year = {2025}
}
